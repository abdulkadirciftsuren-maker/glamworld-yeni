rules_version = '2';
// GROXORG Firebase Storage Güvenlik Kuralları (VİDEO yükleme)
// Firebase Console > Storage > Rules sekmesine YAPIŞTIR + Publish (Yayınla).
// Herkes videoyu OKUR (akışta oynatılır); SADECE giriş yapan kendi klasörüne yazar; en fazla 80MB; sadece video.
service firebase.storage {
  match /b/{bucket}/o {

    match /videolar/{uid}/{dosya=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 80 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }

    // (İleride) profil/iş fotoğrafları için ayrı klasör
    match /gorseller/{uid}/{dosya=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
